{
  "name": "ruyabilinci",
  "version": "1.0.0",
  "description": "Rüya Bilinci - Türkiye'nin en kapsamlı rüya tabirleri platformu",
  "scripts": {
    "dev": "next dev",
    "prebuild": "prisma generate",
    "vercel-build": "prisma migrate deploy && next build",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "ts-node --project tsconfig.scripts.json ./scripts/import-dreams.ts",
    "generate-content": "ts-node --project tsconfig.scripts.json ./scripts/generate-content.ts",
    "generate-content:empty": "ts-node --project tsconfig.scripts.json ./scripts/generate-content.ts --only-empty",
    "analyze-quality": "ts-node --project tsconfig.scripts.json scripts/analyze-content-quality.ts",
    "quarantine-risks": "ts-node --project tsconfig.scripts.json scripts/quarantine-adsense-risks.ts",
    "fix-boilerplate": "ts-node --project tsconfig.scripts.json scripts/fix-boilerplate-content.ts",
    "clean-dirty": "ts-node --project tsconfig.scripts.json scripts/clean-dirty-database.ts",
    "fix-adsense": "ts-node --project tsconfig.scripts.json scripts/fix-adsense-violations.ts",
    "fix-adsense-v2": "ts-node --project tsconfig.scripts.json scripts/fix-adsense-violations-v2.ts",
    "fix-adsense-comprehensive": "ts-node --project tsconfig.scripts.json scripts/fix-adsense-comprehensive.ts",
    "clean-semicolons": "ts-node --project tsconfig.scripts.json scripts/clean-semicolon-artifacts.ts",
    "clean-teasers": "ts-node --project tsconfig.scripts.json scripts/clean-teasers-semicolons.ts",
    "fix-remaining-sug": "ts-node --project tsconfig.scripts.json scripts/fix-remaining-sug.ts",
    "audit:lighthouse:prod": "node scripts/lighthouse-prod.cjs",
    "audit:lighthouse:prod:desktop": "node scripts/lighthouse-prod.cjs --desktop",
    "audit:lighthouse:prod:mobile": "node scripts/lighthouse-prod.cjs --mobile",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.3.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.3.1",
    "jose": "^6.1.3",
    "next": "^14.2.35",
    "pg": "^8.19.0",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "lighthouse": "^13.0.3",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2"
  }
}
